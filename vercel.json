{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "web_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health",      "dest": "https://luminous-endurance-production-0696.up.railway.app/health" },
    { "src": "/convert",     "dest": "https://luminous-endurance-production-0696.up.railway.app/convert" },
    { "src": "/jobs/(.*)",   "dest": "https://luminous-endurance-production-0696.up.railway.app/jobs/$1" },
    { "src": "/files/(.*)",  "dest": "https://luminous-endurance-production-0696.up.railway.app/files/$1" },
    { "src": "/social",      "dest": "https://luminous-endurance-production-0696.up.railway.app/social" },
    { "src": "/social/(.*)", "dest": "https://luminous-endurance-production-0696.up.railway.app/social/$1" },
    { "src": "/(.*)",        "dest": "web_app.py" }
  ]
}
